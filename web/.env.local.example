NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (test keys from dashboard.stripe.com → Developers → API Keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Glovo courier dispatch (Logistics-as-a-Service). OPTIONAL — leave KEY/SECRET blank to disable
# (the whole integration no-ops, zero effect on the order flow). Credentials come from the Glovo
# Business dashboard → Profile → Credentials (sandbox: business.testglovo.com).
#   GLOVO_API_ENV=mock  → run the full flow with realistic FAKE data, NO account/keys needed
#                         (distance-based quotes, fake dispatch + courier). Great for demo/testing.
#   GLOVO_API_ENV=sandbox | production  → hit the real API (requires KEY + SECRET below).
GLOVO_API_ENV=sandbox            # mock | sandbox | production
GLOVO_API_KEY=
GLOVO_API_SECRET=

